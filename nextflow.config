// nextflow.config

params {
    reads       = "data/*_{1,2}.fastq.gz"
    sra_csv     = "metadata/SraRunTable.csv"
    outdir      = "results"
    use_scratch = true

    reference = [
        species    : "Sus scrofa",
        assembly   : "Sscrofa11.1",
        provider   : "Ensembl",
        release    : "111",
        fasta_file : "Sus_scrofa.Sscrofa11.1.dna.toplevel.fa",
        gtf_file   : "Sus_scrofa.Sscrofa11.1.111.gtf",
        fasta_url  : "https://ftp.ensembl.org/pub/release-111/fasta/sus_scrofa/dna/Sus_scrofa.Sscrofa11.1.dna.toplevel.fa.gz",
        gtf_url    : "https://ftp.ensembl.org/pub/release-111/gtf/sus_scrofa/Sus_scrofa.Sscrofa11.1.111.gtf.gz"
    ]

    experimental_design = [
        study_accession     : "SRP287588",
        bioproject          : "PRJNA669819",
        organism            : "Sus scrofa",
        tissue              : "Liver",
        age                 : "d28",
        assay               : "RNA-Seq",
        library_layout      : "PAIRED",
        library_selection   : "cDNA",
        library_source      : "TRANSCRIPTOMIC",
        sequencing_platform : "Illumina NextSeq 500",
        metadata_source     : "NCBI SRA Run Selector export",
        sample_column       : "Run",
        treatment_column    : "treatment",
        treatment_delimiter : ";",
        condition_levels    : ["CTR", "PFA", "OO", "PFA_OO"],
        condition_labels    : [
            CTR    : "Control",
            PFA    : "Phytogenic feed additive",
            OO     : "Oxidized oil",
            PFA_OO : "Phytogenic feed additive and oxidized oil"
        ],
        sample_ids          : [
            CTR    : ["SRR12835320", "SRR12835321", "SRR12835322", "SRR12835323", "SRR12835324", "SRR12835325"],
            PFA    : ["SRR12835326", "SRR12835327", "SRR12835328", "SRR12835329", "SRR12835330", "SRR12835331"],
            OO     : ["SRR12835332", "SRR12835333", "SRR12835334", "SRR12835335", "SRR12835336", "SRR12835337"],
            PFA_OO : ["SRR12835338", "SRR12835339", "SRR12835341", "SRR12835342", "SRR12835343", "SRR12835344"]
        ],
        sample_counts       : [
            CTR    : 6,
            PFA    : 6,
            OO     : 6,
            PFA_OO : 6
        ],
        total_samples       : 24,
        design_formula      : "~ condition",
        contrast_scope      : "Likelihood-ratio test across all four treatment conditions"
    ]

    star = [
        sjdb_overhang : 99
    ]

    star_cpus = 4
    star_max_forks = 2

    counts = [
        strandedness : "reverse"
    ]

    analysis = [
        min_unique_mapping_percent : 65.2,
        padj_cutoff                : 0.1,
        top_gene_count             : 2762,
        min_cluster_size           : 50
    ]

    enrichment = [
        cluster_id      : 1,
        biomart_dataset : "sscrofa_gene_ensembl",
        ontology        : "ALL",
        p_adjust_method : "BH",
        pvalue_cutoff   : 0.1,
        qvalue_cutoff   : 0.1,
        top_terms       : 15
    ]
}

apptainer {
    enabled = true
    autoMounts = true
    cacheDir = "$baseDir/.apptainer_cache"
}

cleanup = true
process.stageInMode = 'symlink'

executor {
    name = 'local'
    cpus = 16
    memory = '100 GB'
    queueSize = 9
}

process {
    // Global execution limits help control disk usage and RAM pressure.
    maxForks = 1

    withName: FASTQC {
        container = "https://depot.galaxyproject.org/singularity/fastqc:0.12.1--hdfd78af_0"
        maxForks = 8
        cpus = 2
    }

    withName: STAR_ALIGN {
        container = "quay.io/biocontainers/star:2.7.11b--h43eeafb_0"
        scratch = params.use_scratch
        cpus = params.star_cpus
        memory = "45 GB"
        maxForks = params.star_max_forks
    }

    withName: PREPARE_REF_GENOME {
        container = "quay.io/biocontainers/star:2.7.11b--h43eeafb_0"
        cpus = 12
    }

    withName: MULTIQC {
        container = "quay.io/biocontainers/multiqc:1.19--pyhdfd78af_0"
    }

    withName: MERGE_MATRIX {
        container = "docker://python:3.10-slim"
    }

    withName: RECREATE_FIG2A {
        container = "docker://ghcr.io/norberth-gif/degreport-test:v2"
        cpus = 8
        memory = "64 GB"
    }

    withName: FUNCTIONAL_ENRICHMENT {
        container = "docker://ghcr.io/norberth-gif/degreport-test:v2"
    }
}

