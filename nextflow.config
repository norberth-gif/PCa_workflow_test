// nextflow.config

params {
    reads       = "data/*_{1,2}.fastq.gz"
    sra_csv     = "metadata/SraRunTable.csv"
    outdir      = "results"
    use_scratch = true
    
    reference = [
        species    : "Homo sapiens",
        assembly   : "GRCh38",
        provider   : "Ensembl",
        release    : "111",
        fasta_file : "Homo_sapiens.GRCh38.dna.primary_assembly.fa",
        gtf_file   : "Homo_sapiens.GRCh38.111.gtf",
        fasta_url  : "https://ftp.ensembl.org/pub/release-111/fasta/homo_sapiens/dna/Homo_sapiens.GRCh38.dna.primary_assembly.fa.gz",
        gtf_url    : "https://ftp.ensembl.org/pub/release-111/gtf/homo_sapiens/Homo_sapiens.GRCh38.111.gtf.gz"
    ]
    
    experimental_design = [

        study_accession     : "SRP393406",
        bioproject          : "PRJNA872110",
        organism            : "Homo sapiens",
        tissue              : "prostate cancer",
    
        assay               : "RNA-Seq",
        library_layout      : "PAIRED",
        library_selection   : "cDNA",
        library_source      : "TRANSCRIPTOMIC",
        sequencing_platform : "Illumina HiSeq 2500",

        metadata_source     : "NCBI SRA Run Selector export",
    
        sample_column       : "Run",
        treatment_column    : "treatment",
    
        condition_levels : [
            "VEH",
            "VEH+Enzalutamide",
            "DHT+VEH",
            "DHT+Enzalutamide"
        ],

        sample_counts : [
            "VEH"                : 2,
            "VEH+Enzalutamide"   : 2,
            "DHT+VEH"            : 2,
            "DHT+Enzalutamide"   : 2
        ],
        
        sample_ids : [

        "VEH" : [
            "SRR21162416",
            "SRR21162417"
        ],

        "VEH+Enzalutamide" : [
            "SRR21162418",
            "SRR21162419"
        ],

        "DHT+Enzalutamide" : [
            "SRR21162420",
            "SRR21162421"
        ],
    
        "DHT+VEH" : [
            "SRR21162422",
            "SRR21162423"
        ]


    ],

        total_samples : 8,

        design_formula : "~ condition",

        contrast_scope : "Likelihood-ratio test across all treatment conditions"
    ]
    



    star = [
        sjdb_overhang : 124
    ]

    star_cpus = 4
    star_max_forks = 2

    counts = [
        strandedness : "reverse"
    ]

    analysis = [
        padj_cutoff                : 0.1,
        min_cluster_size           : 50,

        volcano_padj        : 0.05,
        volcano_log2fc      : 1
    ]

    enrichment = [
        cluster_id      : 1,
        biomart_dataset : "hsapiens_gene_ensembl",
        ontology        : "ALL",
        p_adjust_method : "BH",
        pvalue_cutoff   : 0.1,
        qvalue_cutoff   : 0.1,
        top_terms       : 15
    ]
}

apptainer {
    enabled = true
    autoMounts = true
    cacheDir = "$baseDir/.apptainer_cache"
}

cleanup = true
process.stageInMode = 'symlink'

executor {
    name = 'local'
    cpus = 16
    memory = '100 GB'
    queueSize = 9
}

process {
    // Global execution limits help control disk usage and RAM pressure.
    maxForks = 1

    withName: FASTQC {
        container = "https://depot.galaxyproject.org/singularity/fastqc:0.12.1--hdfd78af_0"
        maxForks = 8
        cpus = 2
    }

    withName: STAR_ALIGN {
        container = "quay.io/biocontainers/star:2.7.11b--h43eeafb_0"
        scratch = params.use_scratch
        cpus = params.star_cpus
        memory = "45 GB"
        maxForks = params.star_max_forks
    }

    withName: PREPARE_REF_GENOME {
        container = "quay.io/biocontainers/star:2.7.11b--h43eeafb_0"
        cpus = 12
    }

    withName: MULTIQC {
        container = "quay.io/biocontainers/multiqc:1.19--pyhdfd78af_0"
    }

    withName: MERGE_MATRIX {
        container = "docker://python:3.10-slim"
    }

    withName: RECREATE_FIG2A {
        container = "docker://ghcr.io/norberth-gif/rnaseq-analysis:v1"        
        cpus = 8
        memory = "64 GB"
    }

    withName: FUNCTIONAL_ENRICHMENT {
        container = "docker://ghcr.io/norberth-gif/rnaseq-analysis:v1"
    }
    
    withName: VOLCANO_PLOT {
        container = "docker://ghcr.io/norberth-gif/rnaseq-analysis:v1"
        cpus = 8
        memory = "64 GB"
    }

}

